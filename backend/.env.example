# --- Application ---
APP_NAME=ALEP Intranet
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Security ---
SECRET_KEY=change-this-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# --- Database (Supabase) ---
# Get these from Supabase: Project Settings -> Database -> Connection string
# For app runtime use the POOLER URL (port 6543, transaction mode).
# For migrations (alembic) use the DIRECT URL (port 5432, session mode).
DATABASE_URL=postgresql+psycopg2://postgres.<project-ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL_DIRECT=postgresql+psycopg2://postgres.<project-ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# --- Supabase API (optional — only if using supabase-py for Auth/Storage/Realtime) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- CORS ---
# Add your Railway frontend domain in production, e.g. https://intranet.alep.pt
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- First Superuser ---
FIRST_SUPERUSER_EMAIL=admin@alep.pt
FIRST_SUPERUSER_PASSWORD=changeme

# --- Railway (set automatically on Railway) ---
# PORT is injected by Railway — uvicorn must bind to it. See start command in railway.toml.
PORT=8000
